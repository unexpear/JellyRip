/* ===========================================================================
 * Catppuccin Mocha (catppuccin_mocha) — dark family
 * Generated by tools/build_qss.py from gui_qt.themes.THEMES.
 * DO NOT EDIT BY HAND.  Edit the tokens in gui_qt/themes.py and re-run.
 *
 * Catppuccin's cozy mocha surface with pastel CTAs — mauve primary, sapphire secondary, teal tertiary, peach caution, red destructive. Low-glare and friendly.
 * ===========================================================================
 */

/* ---- Base palette --------------------------------------------------- */

QMainWindow,
QDialog#wizardDialog,
QDialog {
    background-color: #1e1e2e;
    color: #cdd6f4;
}

QWidget {
    background-color: transparent;
    color: #cdd6f4;
    font-family: "Segoe UI", "Inter", system-ui, sans-serif;
    font-size: 13px;
}

QFrame#sectionDivider {
    background-color: #45475a;
    max-height: 1px;
    border: none;
}

/* ---- Headers + section labels --------------------------------------- */

QLabel#stepHeader {
    color: #cba6f7;
    font-size: 18px;
    font-weight: 700;
    padding: 8px 0 4px 0;
}

QLabel#stepSubtitle {
    color: #9399b2;
    font-size: 12px;
    padding: 0 0 8px 0;
}

QLabel#sectionHeader {
    color: #9399b2;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 12px 0 4px 0;
}

QLabel#scaffoldingPlaceholder {
    color: #9399b2;
    font-size: 14px;
    padding: 24px;
}

/* ---- Wizard rows + scrollers ---------------------------------------- */

QScrollArea#classifiedTitlesScroll {
    background-color: #181825;
    border: 1px solid #45475a;
    border-radius: 6px;
}

QWidget#classifiedTitlesBody {
    background-color: #181825;
}

QFrame#classifiedTitleRow,
QFrame#contentMappingRow {
    background-color: #181825;
    border-bottom: 1px solid #45475a;
    padding: 6px 10px;
}

QLabel#titleNumber {
    color: #cdd6f4;
    font-weight: 600;
}

QLabel#confidencePercent,
QLabel#durationSize,
QLabel#titleReason,
QLabel#sessionDetailLine,
QLabel#scanSummaryRow,
QLabel#driveDiscType,
QLabel#destinationPath {
    color: #9399b2;
    font-size: 12px;
}

/* Classification labels — MAIN reads success-toned, EXTRA info-toned,
 * DUPLICATE/UNKNOWN muted.  Per-category tinting helps users see at a
 * glance which titles will be ripped vs. ignored. */
QLabel#classificationLabel_MAIN {
    color: #8839ef;
    font-weight: 600;
}
QLabel#classificationLabel_EXTRA {
    color: #3a6cc9;
    font-weight: 600;
}
QLabel#classificationLabel_DUPLICATE,
QLabel#classificationLabel_UNKNOWN {
    color: #9399b2;
    font-weight: 600;
}

/* ---- Tree view (output plan) ---------------------------------------- */

QTreeView#outputTreeView,
QTreeWidget#outputTreeView {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    selection-background-color: #45475a;
    selection-color: #ffffff;
}

QTreeView::item:hover,
QTreeWidget::item:hover {
    background-color: #313244;
}

/* ---- Form controls -------------------------------------------------- */

QLineEdit,
QPlainTextEdit,
QTextEdit {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 5px;
    padding: 6px 10px;
    selection-background-color: #45475a;
    selection-color: #ffffff;
}

QLineEdit:focus,
QPlainTextEdit:focus,
QTextEdit:focus {
    border-color: #cba6f7;
}

QComboBox {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 5px;
    padding: 5px 10px;
    min-height: 20px;
}

QComboBox:hover {
    border-color: #cba6f7;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 18px;
    border: none;
}

QComboBox QAbstractItemView {
    background-color: #181825;
    color: #cdd6f4;
    border: 1px solid #45475a;
    selection-background-color: #45475a;
    selection-color: #ffffff;
    outline: none;
}

/* Disabled combo entries use the theme's muted color so they read as
 * unavailable and stay legible in every theme - no baked hex. */
QComboBox QAbstractItemView::item:disabled {
    color: #9399b2;
}

QCheckBox {
    color: #cdd6f4;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #45475a;
    border-radius: 3px;
    background-color: #313244;
}

QCheckBox::indicator:hover {
    border-color: #cba6f7;
}

QCheckBox::indicator:checked {
    background-color: #8839ef;
    border-color: #8839ef;
}

QCheckBox#contentMappingCheckbox {
    /* same style as base QCheckBox; selector pinned for theming drift */
}

/* ---- Buttons -------------------------------------------------------- */

QPushButton {
    background-color: #181825;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 5px;
    padding: 7px 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #313244;
    border-color: #cba6f7;
}

QPushButton:disabled {
    color: #9399b2;
    border-color: #45475a;
    background-color: #181825;
}

QPushButton:focus {
    outline: none;
    border-color: #cba6f7;
}

/* Primary CTA — "Next", "Confirm", "Start Rip".
 * Maps to the ``go`` role.  Bold + colored to draw the eye. */
QPushButton#confirmButton {
    background-color: #8839ef;
    color: #f5e0dc;
    border: 1px solid #8839ef;
    font-weight: 700;
}
QPushButton#confirmButton:hover {
    background-color: #8839ef;
    border-color: #f5e0dc;
}
QPushButton#confirmButton:disabled {
    background-color: #181825;
    color: #9399b2;
    border-color: #45475a;
}

/* Workflow choice button — "Movie", "TV".
 * Maps to the ``info`` role. */
QPushButton#primaryButton {
    background-color: #3a6cc9;
    color: #f5e0dc;
    border: 1px solid #3a6cc9;
    font-weight: 600;
}
QPushButton#primaryButton:hover {
    background-color: #3a6cc9;
    border-color: #f5e0dc;
}

/* Workflow alt button — "Standard".
 * Maps to the ``alt`` role. */
QPushButton#secondaryButton {
    background-color: #1a8f8f;
    color: #f5e0dc;
    border: 1px solid #1a8f8f;
    font-weight: 600;
}
QPushButton#secondaryButton:hover {
    background-color: #1a8f8f;
    border-color: #f5e0dc;
}

/* De-emphasised — "Cancel".  Just a bordered chip in the muted color. */
QPushButton#cancelButton {
    background-color: transparent;
    color: #9399b2;
    border: 1px solid #45475a;
    font-weight: 500;
}
QPushButton#cancelButton:hover {
    color: #cdd6f4;
    background-color: #313244;
    border-color: #45475a;
}

/* ---- Progress / scrollbars ----------------------------------------- */

QProgressBar {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 6px;
    text-align: center;
    color: #cdd6f4;
    height: 8px;
}

QProgressBar::chunk {
    background-color: #cba6f7;
    border-radius: 6px;
}

QScrollBar:vertical {
    background: #1e1e2e;
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #45475a;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover {
    background: #9399b2;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollBar:horizontal {
    background: #1e1e2e;
    height: 10px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: #45475a;
    border-radius: 5px;
    min-width: 24px;
}
QScrollBar::handle:horizontal:hover {
    background: #9399b2;
}
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}

/* ---- Main window shell (Phase 3c-i) -------------------------------- */
/* Layout chrome introduced by ``gui_qt/main_window.py``.  Each rule
 * targets the objectName the shell sets so per-theme coloring
 * happens entirely in QSS.  No colors hard-coded in Python. */

QMainWindow#mainWindow,
QWidget#mainCentral {
    background-color: #1e1e2e;
}

/* App header — centered, accent-colored title with monospace subtitle */
QFrame#appHeader {
    background-color: #181825;
    border-bottom: 1px solid #45475a;
}
QLabel#appHeaderTitle {
    color: #cba6f7;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
}
QLabel#appHeaderSubtitle {
    color: #9399b2;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.2px;
}

/* Drive row */
QFrame#driveRow {
    background-color: transparent;
}
QLabel#driveLabel {
    color: #9399b2;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-right: 4px;
}
QComboBox#driveCombo {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 7px 12px;
    min-height: 22px;
}
QComboBox#driveCombo:hover {
    border-color: #cba6f7;
}
QPushButton#driveRefresh {
    background-color: #313244;
    color: #9399b2;
    border: 1px solid #45475a;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
}
QPushButton#driveRefresh:hover {
    background-color: #313244;
    color: #cba6f7;
    border-color: #cba6f7;
}

/* Utility toolbar — top-docked QToolBar (replaces the chip row) */
QToolBar#utilityToolBar {
    background-color: #1e1e2e;
    border: none;
    border-bottom: 1px solid #45475a;
    padding: 4px 16px;
    spacing: 4px;
}
QToolBar#utilityToolBar::separator {
    background-color: #45475a;
    width: 1px;
    margin: 4px 8px;
}
QToolButton#utilSettings,
QToolButton#utilUpdates,
QToolButton#utilCopyLog,
QToolButton#utilBrowse {
    background-color: transparent;
    color: #9399b2;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
}
QToolButton#utilSettings:hover,
QToolButton#utilUpdates:hover,
QToolButton#utilCopyLog:hover,
QToolButton#utilBrowse:hover {
    background-color: #313244;
    color: #cdd6f4;
    border-color: #45475a;
}
QToolButton#utilSettings:pressed,
QToolButton#utilUpdates:pressed,
QToolButton#utilCopyLog:pressed,
QToolButton#utilBrowse:pressed {
    background-color: #45475a;
    color: #cdd6f4;
}
/* Legacy QPushButton#utilXxx selectors kept while build_qss.py
 * regenerates the .qss files — purges below if anything else
 * still constructs the old chip row.  Safe to remove next pass. */
QPushButton#utilSettings,
QPushButton#utilUpdates,
QPushButton#utilCopyLog,
QPushButton#utilBrowse {
    background-color: transparent;
    color: #9399b2;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
}
QPushButton#utilSettings:hover,
QPushButton#utilUpdates:hover,
QPushButton#utilCopyLog:hover,
QPushButton#utilBrowse:hover {
    background-color: #313244;
    color: #cdd6f4;
    border-color: #45475a;
}

/* Workflow button rows */
QFrame#primaryButtonRow,
QFrame#secondaryButtonRow {
    background-color: transparent;
}

/* Mode buttons — colored per role.  ObjectName prefix encodes role:
 *   modeGo*    → go    (TV, Movie — primary action)
 *   modeInfo*  → info  (Dump All Titles — secondary action)
 *   modeAlt*   → alt   (Organize MKVs — tertiary action)
 *   modeWarn*  → warn  (Prep MKVs — caution)
 */
QPushButton[objectName^="modeGo"] {
    background-color: #8839ef;
    color: #f5e0dc;
    border: 1px solid #8839ef;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton[objectName^="modeGo"]:hover {
    border-color: #f5e0dc;
}
QPushButton[objectName^="modeInfo"] {
    background-color: #3a6cc9;
    color: #f5e0dc;
    border: 1px solid #3a6cc9;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton[objectName^="modeInfo"]:hover {
    border-color: #f5e0dc;
}
QPushButton[objectName^="modeAlt"] {
    background-color: #1a8f8f;
    color: #f5e0dc;
    border: 1px solid #1a8f8f;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton[objectName^="modeAlt"]:hover {
    border-color: #f5e0dc;
}
QPushButton[objectName^="modeWarn"] {
    background-color: #b06a2c;
    color: #f5e0dc;
    border: 1px solid #b06a2c;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
}
QPushButton[objectName^="modeWarn"]:hover {
    border-color: #f5e0dc;
}

/* Stop session — destructive (danger) role */
QFrame#stopRow {
    background-color: transparent;
}
QPushButton#stopButton {
    background-color: transparent;
    color: #c4344a;
    border: 1px solid #c4344a;
    border-radius: 6px;
    padding: 7px 22px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
}
QPushButton#stopButton:hover {
    background-color: #c4344a;
    color: #f5e0dc;
}
QPushButton#stopButton:disabled {
    color: #9399b2;
    border-color: #45475a;
}

/* Log panel header — small label + LED indicator above the log pane */
QFrame#logPanelHeader {
    background-color: transparent;
}
QLabel#logLabel {
    color: #9399b2;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
}
QLabel#logLed {
    color: #9399b2;
    font-size: 10px;
    font-family: ui-monospace, "JetBrains Mono", "Consolas", monospace;
}

/* Log pane itself */
QPlainTextEdit#logPane {
    background-color: #181825;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    margin: 0 24px 16px 24px;
    padding: 10px 14px;
    font-family: "Consolas", ui-monospace, "JetBrains Mono", monospace;
    font-size: 12px;
    selection-background-color: #45475a;
}

/* Status bar — label + progress bar.  Per-role label coloring uses
 * the four objectNames the StatusBar widget assigns based on
 * status_role_for_message(). */
QWidget#statusBar {
    background-color: transparent;
    margin: 4px 24px 0 24px;
}
QLabel#statusReady {
    color: #9399b2;
    font-style: italic;
    font-size: 12px;
}
QLabel#statusBusy {
    color: #cba6f7;
    font-style: italic;
    font-size: 12px;
}
QLabel#statusWarn {
    color: #b06a2c;
    font-style: italic;
    font-size: 12px;
}
QLabel#statusError {
    color: #c4344a;
    font-style: italic;
    font-size: 12px;
}
QProgressBar#statusProgress {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 4px;
    text-align: center;
    color: #cdd6f4;
    height: 14px;
    font-size: 10px;
}
QProgressBar#statusProgress::chunk {
    background-color: #cba6f7;
    border-radius: 4px;
}

/* ---- Tooltip -------------------------------------------------------- */

QToolTip {
    background-color: #181825;
    color: #cdd6f4;
    border: 1px solid #45475a;
    padding: 4px 8px;
}
