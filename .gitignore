# Secrets
.env

# PyInstaller build artifacts

# Keep bundled runtime files explicit and ignore generated app binaries
build/
dist/main/*
!dist/main/.gitkeep
dist/ffmpeg.exe
dist/ffplay.exe
dist/ffprobe.exe
dist/JellyRip.exe
dist/JellyRipInstaller.exe

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.profiles/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Config
config.json
*.log
rip_log.txt

# Local snapshot helpers
.git_head_now.txt
.git_status_now.txt

# Session debris (pytest log, diff scratch, codex auto-backups)
..txt
origin_main_controller.tmp
.codex_backup/

# Claude IDE artifacts — local tool permission allowlists, session
# transcripts, worktrees, plus the per-project working-memory file.
# CLAUDE.md was committed before but its content is duplicated in
# README.md / docs/repository-layout.md / docs/architecture.md;
# keeping CLAUDE.md local-only avoids leaking Claude-directive
# content (working preferences, etc.) to the remote.
.claude/
!.claude/.gitkeep
CLAUDE.md

# Local-only experiments + test artifacts that aren't part of the
# project source.
experiments/
tests/_test_qss_empty_placeholder_tmp/
